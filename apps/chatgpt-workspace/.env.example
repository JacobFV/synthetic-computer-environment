# Optional server-wide model credentials. Users can also connect encrypted credentials in Settings.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DASHSCOPE_API_KEY=

# Optional web-search adapter
TAVILY_API_KEY=

# Database. Leave blank to use ./workspace.db locally.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Required in production. Generate at least 32 random bytes.
APP_ENCRYPTION_KEY=

# OpenRouter attribution and absolute application URL
APP_URL=http://localhost:3000
